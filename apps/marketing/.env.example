# Marketing app environment variables
# Copy to .env.local and fill in real values

# Resend email API key (get from resend.com)
RESEND_API_KEY=re_...

# Email address to receive new contact form submissions
CONTACT_NOTIFY_EMAIL=team@gateflow.io

# From address for outgoing emails (must be a verified Resend domain)
CONTACT_FROM_EMAIL=noreply@gateflow.io

# Marketing tracking (optional)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
