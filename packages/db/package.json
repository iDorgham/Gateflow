{
  "name": "@gate-access/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./quota": "./src/quota.ts",
    "./access": "./src/access.ts"
  },
  "scripts": {
