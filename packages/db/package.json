{
  "name": "@gate-access/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./quota": "./src/quota.ts",
    "./access": "./src/access.ts"
  },
  "scripts": {
    "test": "bun test --preload ./src/setup.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:studio": "prisma studio",
    "seed:compounds": "npx tsx prisma/seed-compounds.ts",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json",
    "postinstall": "prisma generate",
    "build": "prisma generate"
  },
  "dependencies": {
    "@gate-access/types": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "faker": "^5.5.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@gate-access/config": "workspace:*",
    "@types/node": "^20.19.33",
    "@types/pg": "^8.18.0",
    "prisma": "^5.22.0",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed_dev.ts",
    "schema": "prisma/schema.prisma"
  }
}