generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  logoUrl   String?
  domain    String?  @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users           User[]
  gates           Gate[]
  gateAssignments GateAssignment[]
  qrCodes         QRCode[]
  webhooks        Webhook[]
  apiKeys         ApiKey[]
  projects        Project[]
  contacts        Contact[]
  units           Unit[]
  roles           Role[]
  residentLimits  ResidentLimit[]

  @@index([deletedAt])
}

model Project {
  id             String       @id @default(cuid())
  name           String
  description    String?
  logoUrl        String?
  coverUrl       String?
  website        String?
  socialMedia    Json?
  location       String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gates          Gate[]
  qrCodes        QRCode[]
  units          Unit[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
}

model Role {
  id             String        @id @default(cuid())
  name           String
  description    String?
  permissions    Json          // Map of permission keys to booleans
  isBuiltIn      Boolean       @default(false)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  users          User[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  avatarUrl    String?
  bio          String?
  passwordHash String
  role         Role          @relation(fields: [roleId], references: [id])
  roleId       String
  organization Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  scanLogs        ScanLog[]
  refreshTokens   RefreshToken[]
  unit            Unit?
  gateAssignments GateAssignment[]

  @@index([organizationId])
  @@index([roleId])
  @@index([deletedAt])
}

model GateAssignment {
  id             String       @id @default(cuid())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  gate           Gate         @relation(fields: [gateId], references: [id], onDelete: Cascade)
  gateId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([userId, gateId])
  @@index([organizationId])
  @@index([userId])
  @@index([gateId])
  @@index([deletedAt])
}

model Gate {
  id           String        @id @default(cuid())
  name         String
  location     String?
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  project      Project?      @relation(fields: [projectId], references: [id])
  projectId    String?
  isActive     Boolean       @default(true)
  lastAccessedAt DateTime?
  latitude             Float?
  longitude            Float?
  locationRadiusMeters Int?
  locationEnforced     Boolean?  @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  scanLogs        ScanLog[]
  qrCodes         QRCode[]
  gateAssignments GateAssignment[]

  @@index([organizationId])
  @@index([projectId])
  @@index([deletedAt])
}

model QRCode {
  id           String        @id @default(cuid())
  code         String        @unique
  type         QRCodeType
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  project      Project?      @relation(fields: [projectId], references: [id])
  projectId    String?
  gate         Gate?         @relation(fields: [gateId], references: [id])
  gateId       String?
  maxUses      Int?
  currentUses  Int           @default(0)
  expiresAt    DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  scanLogs  ScanLog[]
  visitorQR VisitorQR?

  @@index([organizationId])
  @@index([projectId])
  @@index([gateId])
  @@index([deletedAt])
  @@index([expiresAt])
}

model ScanLog {
  id        String     @id @default(cuid())
  scanUuid  String?    @unique
  status    ScanStatus
  scannedAt DateTime   @default(now())
  user      User?      @relation(fields: [userId], references: [id])
  userId    String?
  gate      Gate       @relation(fields: [gateId], references: [id], onDelete: Cascade)
  gateId    String
  qrCode    QRCode     @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  qrCodeId  String
  deviceId  String?
  auditNotes Json?
  auditTrail Json[]

  @@index([gateId])
  @@index([qrCodeId])
  @@index([userId])
  @@index([scannedAt])
  @@index([qrCodeId, scannedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Webhook {
  id             String         @id @default(cuid())
  url            String
  events         WebhookEvent[]
  secret         String
  isActive       Boolean        @default(true)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  deliveries WebhookDelivery[]

  @@index([organizationId])
  @@index([deletedAt])
}

model WebhookDelivery {
  id            String                @id @default(cuid())
  webhook       Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  webhookId     String
  event         WebhookEvent
  payload       Json
  status        WebhookDeliveryStatus
  statusCode    Int?
  responseBody  String?
  attemptCount  Int                   @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime              @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

enum Plan {
  FREE
  PRO
}

enum QRCodeType {
  SINGLE
  RECURRING
  PERMANENT
  VISITOR
  OPEN
}

enum ScanStatus {
  SUCCESS
  FAILED
  EXPIRED
  MAX_USES_REACHED
  INACTIVE
  DENIED
}

enum WebhookEvent {
  QR_CREATED
  QR_SCANNED
  QR_REVOKED
  QR_EXPIRED
  SCAN_SUCCESS
  SCAN_FAILED
}

enum WebhookDeliveryStatus {
  PENDING
  RETRYING
  SUCCESS
  FAILED
}

model ApiKey {
  id             String     @id @default(cuid())
  name           String
  keyHash        String     @unique
  keyPrefix      String
  scopes         ApiScope[]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime   @default(now())
  createdBy      String

  @@index([organizationId])
  @@index([keyHash])
}

enum ApiScope {
  QR_CREATE
  QR_READ
  QR_VALIDATE
  SCANS_READ
  ANALYTICS_READ
  WEBHOOK_WRITE
}

model QrShortLink {
  id             String    @id @default(cuid())
  shortId        String    @unique
  fullPayload    String
  qrId           String
  organizationId String
  projectId      String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@index([shortId])
  @@index([organizationId])
  @@index([qrId])
}

model Contact {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  birthday       DateTime?
  company        String?
  phone          String?
  email          String?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  units ContactUnit[]

  @@index([organizationId])
  @@index([deletedAt])
}

model Unit {
  id             String        @id @default(cuid())
  name           String        // Matches unitNumber from spec
  type           UnitType
  qrQuota        Int?          // Optional, falls back to organization defaults
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  project        Project?      @relation(fields: [projectId], references: [id])
  projectId      String?
  building       String?
  user           User?         @relation(fields: [userId], references: [id])
  userId         String?       @unique // Linked resident user
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  contacts   ContactUnit[]
  visitorQRs VisitorQR[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([deletedAt])
}

model ContactUnit {
  contactId String
  unitId    String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  unit      Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([contactId, unitId])
  @@index([contactId])
  @@index([unitId])
}

model VisitorQR {
  id              String        @id @default(cuid())
  qrCode          QRCode        @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  qrCodeId        String        @unique
  unit            Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId          String
  visitorName     String?       // Optional - null for Open QR
  visitorPhone    String?       // Optional
  visitorEmail    String?       // Optional
  isOpenQR        Boolean       @default(false) // Open QR - no name required
  accessRule      AccessRule?   @relation(fields: [accessRuleId], references: [id])
  accessRuleId    String?       @unique
  createdBy       String        // userId of resident
  createdAt       DateTime      @default(now())

  @@index([unitId])
  @@index([createdBy])
}

model AccessRule {
  id              String            @id @default(cuid())
  type            AccessRuleType    // ONETIME, DATERANGE, RECURRING
  startDate       DateTime?
  endDate         DateTime?
  recurringDays   Int[]            // Days of week (0-6, Sunday=0)
  startTime       String?           // "09:00" format
  endTime         String?           // "22:00" format
  visitorQR       VisitorQR?

  @@index([startDate])
}

model ResidentLimit {
  id              String   @id @default(cuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  unitType        UnitType
  monthlyQuota    Int      // Max visitors per month
  canCreateOpenQR Boolean @default(false) // Whether unit type can create Open QR
  createdAt       DateTime @default(now())

  @@unique([organizationId, unitType])
}

enum UnitType {
  STUDIO
  ONE_BR
  TWO_BR
  THREE_BR
  FOUR_BR
  VILLA
  PENTHOUSE
  COMMERCIAL
}

enum AccessRuleType {
  ONETIME       // Single use, specific date
  DATERANGE    // Multiple uses within date range
  RECURRING    // Recurring access (daily/weekly)
  PERMANENT    // No time limits (Open QR default)
}
