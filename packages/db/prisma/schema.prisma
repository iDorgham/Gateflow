generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                            String                  @id @default(cuid())
  name                          String
  email                         String                  @unique
  domain                        String?                 @unique
  plan                          Plan                    @default(FREE)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  deletedAt                     DateTime?
  logoUrl                       String?
  /// Visitor identity level: 0=name/phone only, 1=ID photo capture, 2=ID OCR (stub)
  requiredIdentityLevel         Int                     @default(0)
  /// null = keep indefinitely
  scanLogRetentionMonths        Int?
  visitorHistoryRetentionMonths Int?
  idArtifactRetentionMonths     Int?
  incidentRetentionMonths       Int?
  maskResidentNameOnLandingPage Boolean                 @default(false)
  showUnitOnLandingPage         Boolean                 @default(true)
  planExpiresAt                 DateTime?
  stripeCustomerId              String?                 @unique
  stripeSubscriptionId          String?                 @unique
  /// Integration config: { gtmId, hubspotPortalId, googleAnalyticsId, ... }
  integrationConfig             Json?
  /// Notification config: { channels: { email, sms, push }, events: { scanSuccess, scanFailed, ... } }
  notificationConfig            Json?
  /// Global scanner config: { offlineModeEnabled, vibrationEnabled, soundEnabled, allowOverride }
  scannerConfig                 Json?
  adminAuthKeys                 AdminAuthorizationKey[]
  apiKeys                       ApiKey[]
  auditLogs                     AuditLog[]
  chatMessages                  ChatMessage[]
  contacts                      Contact[]
  eventLogs                     EventLog[]
  gates                         Gate[]
  gateAssignments               GateAssignment[]
  incidents                     Incident[]
  invitations                   Invitation[]
  projects                      Project[]
  qrCodes                       QRCode[]
  residentLimits                ResidentLimit[]
  roles                         Role[]
  scanAttachments               ScanAttachment[]
  tags                          Tag[]
  tasks                         Task[]
  units                         Unit[]
  users                         User[]
  watchlistEntries              WatchlistEntry[]
  webhooks                      Webhook[]

  @@index([deletedAt])
}

model Project {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  coverUrl       String?
  description    String?
  location       String?
  logoUrl        String?
  socialMedia    Json?
  website        String?
  /// Array of image URL strings for the project gallery
  galleryJson    Json?
  /// External marketing / landing-page URL (distinct from website)
  externalUrl    String?
  gateMode       GateMode     @default(MULTI)
  gates          Gate[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  qrCodes        QRCode[]
  units          Unit[]

  @@index([organizationId])
}

model Role {
  id             String        @id @default(cuid())
  name           String
  description    String?
  permissions    Json
  isBuiltIn      Boolean       @default(false)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invitations    Invitation[]
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]

  @@index([organizationId])
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  passwordHash    String
  organizationId  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  avatarUrl       String?
  bio             String?
  /// e.g. { tableViews: { contacts: {...}, units: {...} } }
  preferences     Json?
  roleId          String
  auditLogs       AuditLog[]
  chatMessages    ChatMessage[]
  gateAssignments GateAssignment[]
  incidents       Incident[]
  refreshTokens   RefreshToken[]
  scanLogs        ScanLog[]
  unit            Unit?
  organization    Organization?    @relation(fields: [organizationId], references: [id])
  role            Role             @relation(fields: [roleId], references: [id])

  @@index([organizationId])
  @@index([roleId])
  @@index([deletedAt])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  roleId         String
  token          String       @unique
  acceptedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id])

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([token])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  dueDate        DateTime?
  organizationId String
  createdBy      String?
  assignedTo     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([deletedAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  content        String
  organizationId String
  userId         String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([createdAt])
}

model GateAssignment {
  id             String       @id @default(cuid())
  userId         String
  gateId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  /// Optional shift start time (HH:mm, 24h). When set, assignment is valid from this time of day.
  shiftStart     String?
  /// Optional shift end time (HH:mm, 24h). When set, assignment is valid until this time of day.
  shiftEnd       String?
  gate           Gate         @relation(fields: [gateId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gateId])
  @@index([organizationId])
  @@index([userId])
  @@index([gateId])
  @@index([deletedAt])
}

model Gate {
  id                    String           @id @default(cuid())
  name                  String
  location              String?
  organizationId        String
  isActive              Boolean          @default(true)
  lastAccessedAt        DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?
  projectId             String?
  latitude              Float?
  longitude             Float?
  locationRadiusMeters  Int?
  locationEnforced      Boolean?         @default(false)
  /// 0/1/2; null = use org default
  requiredIdentityLevel Int?
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project               Project?         @relation(fields: [projectId], references: [id])
  gateAssignments       GateAssignment[]
  incidents             Incident[]
  qrCodes               QRCode[]
  scanLogs              ScanLog[]

  @@index([organizationId])
  @@index([projectId])
  @@index([deletedAt])
}

model WatchlistEntry {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  idNumber       String?
  phone          String?
  notes          String?
  createdBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([deletedAt])
}

model Incident {
  id             String           @id @default(cuid())
  organizationId String
  gateId         String
  userId         String?
  scanLogId      String?
  reason         String
  status         IncidentStatus   @default(UNDER_REVIEW)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  gate           Gate             @relation(fields: [gateId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scanLog        ScanLog?         @relation(fields: [scanLogId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  attachments    ScanAttachment[]

  @@index([organizationId])
  @@index([gateId])
  @@index([status])
  @@index([createdAt])
}

model ScanAttachment {
  id             String       @id @default(cuid())
  organizationId String
  scanLogId      String?
  incidentId     String?
  /// id_front, id_back, etc.
  type           String
  /// MVP: base64 image; future: storage key
  contentBase64  String?
  createdAt      DateTime     @default(now())
  incident       Incident?    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scanLog        ScanLog?     @relation(fields: [scanLogId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([scanLogId])
  @@index([incidentId])
}

model QRCode {
  id             String       @id @default(cuid())
  code           String       @unique
  type           QRCodeType
  organizationId String
  gateId         String?
  maxUses        Int?
  currentUses    Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  projectId      String?
  utmCampaign    String?
  utmSource      String?
  /// Optional reference to Contact.id (no enforced FK for migration atomicity)
  contactId      String?
  guestEmail     String?
  guestName      String?
  guestPhone     String?
  gate           Gate?        @relation(fields: [gateId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?     @relation(fields: [projectId], references: [id])
  scanLogs       ScanLog[]
  visitorQR      VisitorQR?

  @@index([organizationId])
  @@index([projectId])
  @@index([gateId])
  @@index([deletedAt])
  @@index([expiresAt])
}

model ScanLog {
  id                String           @id @default(cuid())
  status            ScanStatus
  scannedAt         DateTime         @default(now())
  userId            String?
  gateId            String
  qrCodeId          String
  scanUuid          String?          @unique
  deviceId          String?
  auditTrail        Json[]
  auditNotes        Json?
  /// Set when the resident receives an "I've arrived" push for this scan (idempotency guard)
  arrivalNotifiedAt DateTime?
  incidents         Incident[]
  attachments       ScanAttachment[]
  gate              Gate             @relation(fields: [gateId], references: [id], onDelete: Cascade)
  qrCode            QRCode           @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  user              User?            @relation(fields: [userId], references: [id])

  @@index([gateId])
  @@index([qrCodeId])
  @@index([userId])
  @@index([scannedAt])
  @@index([qrCodeId, scannedAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organizationId String
  userId         String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Webhook {
  id             String            @id @default(cuid())
  url            String
  events         WebhookEvent[]
  secret         String
  isActive       Boolean           @default(true)
  organizationId String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]

  @@index([organizationId])
  @@index([deletedAt])
}

model WebhookDelivery {
  id            String                @id @default(cuid())
  webhookId     String
  event         WebhookEvent
  payload       Json
  status        WebhookDeliveryStatus
  statusCode    Int?
  responseBody  String?
  attemptCount  Int                   @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime              @default(now())
  webhook       Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique
  keyPrefix      String
  scopes         ApiScope[]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  organizationId String
  createdAt      DateTime     @default(now())
  createdBy      String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

model AdminAuthorizationKey {
  id             String           @id @default(cuid())
  name           String
  keyHash        String           @unique
  keyPrefix      String
  type           AdminAuthKeyType
  organizationId String?
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime         @default(now())
  createdBy      String
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
}

model QrShortLink {
  id             String    @id @default(cuid())
  shortId        String    @unique
  fullPayload    String
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  qrId           String
  organizationId String
  projectId      String?

  @@index([shortId])
  @@index([organizationId])
  @@index([qrId])
}

model Tag {
  id             String       @id @default(cuid())
  name           String
  color          String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  contacts       ContactTag[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([deletedAt])
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

model Contact {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  birthday       DateTime?
  company        String?
  phone          String?
  email          String?
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  avatarUrl      String?
  /// Job title / role at the company
  jobTitle       String?
  /// How the contact entered the system
  source         ContactSource?
  /// Company or personal website URL
  companyWebsite String?
  /// Free-text notes about the contact
  notes          String?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactTags    ContactTag[]
  units          ContactUnit[]

  @@index([organizationId])
  @@index([deletedAt])
}

model Unit {
  id             String        @id @default(cuid())
  name           String
  type           UnitType
  qrQuota        Int?
  organizationId String
  projectId      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  sizeSqm        Int?
  building       String?
  isActive       Boolean       @default(true)
  userId         String?       @unique
  /// Unit latitude for GPS guest guide
  lat            Float?
  /// Unit longitude for GPS guest guide
  lng            Float?
  contacts       ContactUnit[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?      @relation(fields: [projectId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
  visitorQRs     VisitorQR[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([deletedAt])
}

model ContactUnit {
  contactId String
  unitId    String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  unit      Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([contactId, unitId])
  @@index([contactId])
  @@index([unitId])
}

model VisitorQR {
  id           String      @id @default(cuid())
  qrCodeId     String      @unique
  unitId       String
  visitorName  String?
  visitorPhone String?
  visitorEmail String?
  isOpenQR     Boolean     @default(false)
  accessRuleId String?     @unique
  createdBy    String
  createdAt    DateTime    @default(now())
  accessRule   AccessRule? @relation(fields: [accessRuleId], references: [id])
  qrCode       QRCode      @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  unit         Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([createdBy])
}

model AccessRule {
  id            String         @id @default(cuid())
  type          AccessRuleType
  startDate     DateTime?
  endDate       DateTime?
  recurringDays Int[]
  startTime     String?
  endTime       String?
  visitorQR     VisitorQR?

  @@index([startDate])
}

model ResidentLimit {
  id              String       @id @default(cuid())
  organizationId  String
  unitType        UnitType
  monthlyQuota    Int
  canCreateOpenQR Boolean      @default(false)
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, unitType])
}

/// Append-only log of org-scoped mutation events, consumed by the SSE stream.
/// Rows are pruned after 24 h — no soft-delete needed.
model EventLog {
  id             String       @id @default(cuid())
  organizationId String
  type           EventType
  payload        Json         @default("{}")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum QRCodeType {
  SINGLE
  RECURRING
  PERMANENT
  VISITOR
  OPEN
}

enum ScanStatus {
  SUCCESS
  FAILED
  EXPIRED
  MAX_USES_REACHED
  INACTIVE
  DENIED
}

enum IncidentStatus {
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

enum WebhookEvent {
  QR_CREATED
  QR_SCANNED
  QR_REVOKED
  QR_EXPIRED
  SCAN_SUCCESS
  SCAN_FAILED
}

enum WebhookDeliveryStatus {
  PENDING
  RETRYING
  SUCCESS
  FAILED
}

enum AdminAuthKeyType {
  ADMIN
  SERVICE
}

enum ApiScope {
  QR_CREATE
  QR_READ
  QR_VALIDATE
  SCANS_READ
  ANALYTICS_READ
  WEBHOOK_WRITE
}

enum UnitType {
  STUDIO
  ONE_BR
  TWO_BR
  THREE_BR
  FOUR_BR
  VILLA
  PENTHOUSE
  COMMERCIAL
}

enum AccessRuleType {
  ONETIME
  DATERANGE
  RECURRING
  PERMANENT
}

/// How a Contact was originally added to the system
enum ContactSource {
  MANUAL
  IMPORT
  QR_SCAN
  REFERRAL
  OTHER
}

/// Whether a Project is configured for a single gate or multiple gates
enum GateMode {
  SINGLE
  MULTI
}

enum EventType {
  QR_CREATED
  QR_UPDATED
  QR_DELETED
  SCAN_RECORDED
  CONTACT_CREATED
  CONTACT_UPDATED
  VISITOR_QR_CREATED
  VISITOR_QR_DELETED
}
