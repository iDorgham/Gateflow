# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gate_access?schema=public"

# Authentication (NEXTAUTH_SECRET is used for JWT signing via jose)
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
# JWT_SECRET can override NEXTAUTH_SECRET for JWT specifically (optional)
# JWT_SECRET=""

# API
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# QR Signing (HMAC-SHA256 — min 32 chars, keep secret!)
QR_SIGNING_SECRET="your-qr-signing-secret-change-in-production"

# App (optional, defaults shown)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (SMTP) — required for /api/qr/send-email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="\"GateFlow\" <noreply@gateflow.io>"

# Redis (Upstash) — required for scalable rate limiting in production
# Get from https://upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Encryption Master Key — required for encrypting sensitive data at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY="your-32-byte-hex-key-here"

# Admin Dashboard Access Key (REQUIRED)
# Must be set to a secure random string (at least 32 chars)
ADMIN_ACCESS_KEY="change-me-to-a-secure-random-string-min-32-chars"

# Stripe (Billing Integration)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_ENTERPRISE="price_..."
